{
    "name": "emailexpert/emailexpert-events",
    "description": "HeySummit connector for WordPress: syncs events, sessions and speakers, renders them with Schema.org markup, and receives registration webhooks.",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Emailexpert\\Events\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Emailexpert\\Events\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "phpcs",
        "test": "phpunit"
    }
}
